{
  "name": "@openclaw/health-data",
  "version": "2026.2.28",
  "description": "OpenClaw health data webhook plugin (ROOK SDK + Apple Health Auto Export)",
  "type": "module",
  "dependencies": {},
  "devDependencies": {
    "openclaw": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/health-data",
      "localPath": "extensions/health-data",
      "defaultChoice": "npm"
    }
  }
}
