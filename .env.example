# Octavius Environment Configuration
# Copy this file to .env.local and fill in your values.

# Memory Service API secret token (used to authenticate /api/health/ingest and /api/memory/* endpoints)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OCTAVIUS_API_SECRET=

# OpenClaw gateway address (default: localhost)
OPENCLAW_GATEWAY_HOST=localhost

# OpenClaw gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Base directory for agent workspace files (default: ~/.openclaw)
# OPENCLAW_HOME=~/.openclaw

# Lossless Context Management (lossless-claw) database path
# Defaults to ~/.openclaw/lcm.db — only change if you moved the LCM database
# LCM_DATABASE_PATH=~/.openclaw/lcm.db

# Obsidian Integration (optional)
# Enable via the dashboard UI (Memory → Obsidian Integration) or set these env vars.
# Requires the Obsidian Local REST API plugin: https://github.com/coddingtonbear/obsidian-local-rest-api
# OBSIDIAN_API_URL=https://127.0.0.1:27124
# OBSIDIAN_API_KEY=your-api-key-from-obsidian-settings
