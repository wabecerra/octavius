# Octavious Environment Configuration
# Copy this file to .env.local and fill in your values.

# Memory Service API secret token (used to authenticate /api/health/ingest and /api/memory/* endpoints)
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OCTAVIOUS_API_SECRET=

# OpenClaw gateway address (default: localhost)
OPENCLAW_GATEWAY_HOST=localhost

# OpenClaw gateway port (default: 18789)
OPENCLAW_GATEWAY_PORT=18789

# Base directory for agent workspace files (default: ~/.openclaw)
# OPENCLAW_HOME=~/.openclaw
